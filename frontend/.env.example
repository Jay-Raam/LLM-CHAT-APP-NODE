# Frontend environment example for Vite
# Point to your backend API base (include /api/v1)
VITE_API_BASE_URL=http://localhost:4000/api/v1

# If using socket.io (optional)
VITE_SOCKET_URL=http://localhost:4000

# Other envs
# NewsData API key (used for suggestion prompts in Dashboard)
VITE_NEWSDATA_API_KEY=your_newsdata_api_key

# VITE_SOMETHING=...
